# ─── ots-teen-agent environment ───────────────────────────────────────────
# Copy to .env for local dev (never commit .env). Set these in Render for prod.

# Anthropic key — powers /api/chat (both the interview and the scoring call).
ANTHROPIC_API_KEY=

# Postgres connection string for durable server-side sessions (opaque session
# ids, cookie auth, durable safety/one-time-send state). If unset, the app falls
# back to a NON-durable in-memory store (dev only) and /api/health reports
# ready:false. Use the Render "Internal Database URL".
DATABASE_URL=

# The teen agent's OWN Make webhook for the approved parent report.
# DO NOT reuse the parent Family Money Story / ots-deep-work webhook.
TEEN_MAKE_WEBHOOK_URL=

# Shared secret sent in the parent-report webhook body as `auth`. The Make
# scenario filters on it so the webhook can't be used as an open email relay.
# Must match the value the Make filter checks.
MAKE_SHARED_SECRET=

# Safety alerts (CRISIS/ABUSE) are emailed DIRECTLY (not via Make) so the
# critical path doesn't depend on a no-code tool's plan/uptime. Gmail address +
# app password (same approach as ots-deep-work). If unset, CRISIS/ABUSE are
# logged server-side but NOT emailed. Alerts never go to the parent.
EMAIL_USER=
EMAIL_PASS=
# Where safety alerts are sent. Defaults to EMAIL_USER if unset.
SAFETY_ALERT_TO=

# TEST-PHASE SESSION RECORDING. When set, a full record (transcript + final
# assessment) of every COMPLETED, non-safety-flagged session is emailed here for
# product improvement. Reuses EMAIL_USER/EMAIL_PASS. Leave UNSET in production —
# clearing this is the on/off switch. Safety-flagged sessions are never archived.
ARCHIVE_EMAIL_TO=

# ─── Funnel analytics (optional; env-guarded — no-op if unset) ──────────────
# Server-side GA4 Measurement Protocol, mirroring the website's click→lead→paid
# events for the Map funnel. BOTH are required to enable GA4 events. Events fired:
# map_registered, map_interview_complete, map_result_viewed, map_report_sent,
# map_pdf_saved, map_share_opened.
GA4_MEASUREMENT_ID=
GA4_MP_API_SECRET=

# Optional CRM sync webhook (a GHL/Make inbound webhook). Receives
# {event, tag, parent_email, parent_first_name, teen_first_name, teen_age} on
# register + report-sent so the Map funnel tags land in GoHighLevel. No-op if unset.
GHL_SYNC_WEBHOOK_URL=

# ─── Go-live gates + retention ─────────────────────────────────────────────
# LAUNCH_MODE = beta (default) | production. In production, /api/health reports
# ready:false unless SAFETY_REVIEW_APPROVED=true AND archiving is off — the
# counsel-signoff gate. Production ALSO hard-disables transcript archiving.
LAUNCH_MODE=beta
# Set to "true" ONLY after the docs/SAFETY-SOP.md [NEEDS COUNSEL] items are signed off.
SAFETY_REVIEW_APPROVED=
# Retention windows (days): session TTL default 30; unshared finished results 7.
SESSION_RETENTION_DAYS=30
UNSHARED_RESULT_RETENTION_DAYS=7

# ─── Paid Map ($47, parent pays upfront — PR E) ────────────────────────────
# PAYMENT_REQUIRED=true makes /api/register require a paid-pass issued by /paid.
# Needs STRIPE_SECRET_KEY (to verify the checkout) and the Stripe Payment Link's
# success URL set to {PUBLIC_BASE_URL}/paid?session_id={CHECKOUT_SESSION_ID}.
# Leave PAYMENT_REQUIRED unset/false for the beta (registration stays open).
PAYMENT_REQUIRED=
MAP_PAYMENT_URL=
STRIPE_SECRET_KEY=
# HMAC key for the paid-pass cookie (falls back to MAKE_SHARED_SECRET if unset).
PAYPASS_SECRET=

# Optional. Base URL used to build the teen link returned by /api/register.
# If unset, it's derived from the incoming request host.
PUBLIC_BASE_URL=

# Render sets PORT automatically; default 3000 locally.
PORT=3000
